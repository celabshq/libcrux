/target
.vscode
.DS_Store
benches/boringssl/build
fuzz/corpus
fuzz/artifacts
__pycache__
kyber-crate/
*.llbc
.cargo/
Cargo.lock

# When using sed
*.bak

# F*
# .fstar-cache is a build cache (ignored).  EXCEPTION: the ml-kem proof's stable F* hints
# are committed so an accidental hint clobber (e.g. a bare `--record_hints` run that
# overwrites instead of merges) is recoverable via `git checkout`.  checked/ and other
# crates' hints stay ignored.  See libcrux-ml-kem/proofs/fstar/HINTS.md.
/.fstar-cache/*
!/.fstar-cache/hints/
/.fstar-cache/hints/*
# ml-kem extraction (generated) + Hacspec_ml_kem specs/commute bridges (hand-written):
!/.fstar-cache/hints/Libcrux_ml_kem.*.hints
!/.fstar-cache/hints/Hacspec_ml_kem.*.hints
# hand-written proof-lib helpers in ml-kem's dependency closure:
!/.fstar-cache/hints/Spec.Utils.*.hints
!/.fstar-cache/hints/Proof_utils.*.hints
!/.fstar-cache/hints/MkSeq.*.hints
!/.fstar-cache/hints/BitVec.*.hints
!/.fstar-cache/hints/Bitvec.*.hints
!/.fstar-cache/hints/BitVecEq.*.hints
!/.fstar-cache/hints/Tactics.*.hints
.depend
/proofs/fstar/*/#*#
/proofs/fstar/*/.#*
hax.fst.config.json
.mcp.json
