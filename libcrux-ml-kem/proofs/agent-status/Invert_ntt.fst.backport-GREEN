          i0:
          Libcrux_ml_kem.Vector.Traits.t_Operations v_Vector)
      (a b: v_Vector)
      (zeta_r: i16)
     =
  let e_a_in:v_Vector = a in
  let e_b_in:v_Vector = b in
  let b_minus_a:v_Vector =
    Libcrux_ml_kem.Polynomial.sub_bounded #v_Vector
      b
      (mk_usize 4 *! mk_usize 3328 <: usize)
      a
      (mk_usize 4 *! mk_usize 3328 <: usize)
  in
  let a_plus_b:v_Vector =
    Libcrux_ml_kem.Polynomial.add_bounded #v_Vector
      a
