val invert_ntt_at_layer_1_
      (#v_Vector: Type0)
      {| i0: Libcrux_ml_kem.Vector.Traits.t_Operations v_Vector |}
      (zeta_i: usize)
      (re: Libcrux_ml_kem.Vector.t_PolynomialRingElement v_Vector)
    : Prims.Pure (usize & Libcrux_ml_kem.Vector.t_PolynomialRingElement v_Vector)
      (requires
        Libcrux_ml_kem.Polynomial.Spec.is_bounded_poly #v_Vector
          (mk_usize 4 *! mk_usize 3328 <: usize)
          re /\ b2t (zeta_i =. mk_usize 128 <: bool))
      (ensures
        fun temp_0_ ->
          let
          (zeta_i_future: usize),
          (re_future: Libcrux_ml_kem.Vector.t_PolynomialRingElement v_Vector) =
            temp_0_
          in
          Libcrux_ml_kem.Polynomial.Spec.is_bounded_poly #v_Vector (mk_usize 3328) re_future /\
          b2t (zeta_i_future =. mk_usize 64 <: bool) /\
          (forall (i: usize).
              i <. mk_usize 16 ==>
              Libcrux_ml_kem.Vector.Traits.Spec.mont_i16_to_spec_array (mk_usize 16)
                (Libcrux_ml_kem.Vector.Traits.f_repr #v_Vector
                    (Seq.index re_future.f_coefficients (v i))) ==
              Hacspec_ml_kem.Invert_ntt.ntt_inverse_layer_n (mk_usize 16)
                (Libcrux_ml_kem.Vector.Traits.Spec.mont_i16_to_spec_array (mk_usize 16)
                    (Libcrux_ml_kem.Vector.Traits.f_repr #v_Vector
                        (Seq.index re.f_coefficients (v i))))
                (mk_usize 2)
                (Rust_primitives.unsize (Libcrux_ml_kem.Vector.Traits.Spec.zetas_4_ (Libcrux_ml_kem.Polynomial.zeta
                            (mk_usize 127 -! mk_usize 4 *! i))
                        (Libcrux_ml_kem.Polynomial.zeta (mk_usize 126 -! mk_usize 4 *! i))
                        (Libcrux_ml_kem.Polynomial.zeta (mk_usize 125 -! mk_usize 4 *! i))
                        (Libcrux_ml_kem.Polynomial.zeta (mk_usize 124 -! mk_usize 4 *! i))))))

